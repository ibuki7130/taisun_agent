{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "GemResearchOutput",
  "description": "gem-research スキルの出力スキーマ。SkillConfig互換。",
  "type": "object",
  "required": ["meta", "keywords", "persona", "tone"],
  "properties": {
    "meta": {
      "type": "object",
      "required": ["skill", "version", "mode", "topic", "timestamp", "sources_count", "layers_used"],
      "properties": {
        "skill": { "type": "string", "const": "gem-research" },
        "version": { "type": "string" },
        "mode": { "type": "string", "enum": ["quick", "standard", "deep", "industry"] },
        "topic": { "type": "string" },
        "preset": { "type": ["string", "null"] },
        "timestamp": { "type": "string", "format": "date-time" },
        "sources_count": { "type": "integer", "minimum": 0 },
        "layers_used": {
          "type": "array",
          "items": { "type": "integer", "minimum": 1, "maximum": 9 }
        },
        "execution_time_seconds": { "type": "integer", "minimum": 0 }
      }
    },
    "keywords": {
      "type": "object",
      "required": ["primary"],
      "properties": {
        "primary": { "type": "array", "items": { "type": "string" }, "minItems": 3 },
        "secondary": { "type": "array", "items": { "type": "string" } },
        "long_tail": { "type": "array", "items": { "type": "string" } },
        "pain_point": { "type": "array", "items": { "type": "string" } },
        "benefit": { "type": "array", "items": { "type": "string" } },
        "competitor": { "type": "array", "items": { "type": "string" } },
        "action": { "type": "array", "items": { "type": "string" } }
      }
    },
    "persona": {
      "type": "object",
      "required": ["primary"],
      "properties": {
        "primary": { "$ref": "#/$defs/personaDetail" },
        "secondary": { "$ref": "#/$defs/personaDetail" }
      }
    },
    "tone": {
      "type": "object",
      "required": ["voice", "formality"],
      "properties": {
        "voice": { "type": "string" },
        "formality": { "type": "string", "enum": ["low", "medium", "high"] },
        "emotion": { "type": "string" },
        "keywords_to_use": { "type": "array", "items": { "type": "string" } },
        "keywords_to_avoid": { "type": "array", "items": { "type": "string" } }
      }
    },
    "content_types": {
      "type": "array",
      "items": { "type": "string" }
    },
    "platforms": {
      "type": "object",
      "properties": {
        "primary": { "type": "array", "items": { "type": "string" } },
        "secondary": { "type": "array", "items": { "type": "string" } },
        "emerging": { "type": "array", "items": { "type": "string" } }
      }
    },
    "hashtags": {
      "type": "object",
      "properties": {
        "instagram": {
          "type": "object",
          "properties": {
            "mega": { "type": "array", "items": { "type": "string" } },
            "large": { "type": "array", "items": { "type": "string" } },
            "medium": { "type": "array", "items": { "type": "string" } },
            "niche": { "type": "array", "items": { "type": "string" } }
          }
        },
        "tiktok": { "type": "array", "items": { "type": "string" } },
        "youtube": { "type": "array", "items": { "type": "string" } },
        "x_twitter": { "type": "array", "items": { "type": "string" } }
      }
    },
    "cta_templates": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["text", "type"],
        "properties": {
          "text": { "type": "string" },
          "type": {
            "type": "string",
            "enum": ["申込み", "相談", "資料請求", "無料体験", "LINE登録", "診断", "購入"]
          },
          "urgency": { "type": "string", "enum": ["low", "medium", "high"] },
          "context": { "type": "string" }
        }
      }
    },
    "competitor_analysis": {
      "type": "object",
      "properties": {
        "ai_competitors": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "platform": { "type": "string" },
              "name": { "type": "string" },
              "features": { "type": "array", "items": { "type": "string" } },
              "gap": { "type": "string" }
            }
          }
        },
        "market_competitors": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "strength": { "type": "string" },
              "weakness": { "type": "string" }
            }
          }
        },
        "differentiation_opportunities": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "customer_voice": {
      "type": "object",
      "properties": {
        "top_concerns": {
          "type": "array",
          "items": { "$ref": "#/$defs/voiceItem" }
        },
        "top_motivations": {
          "type": "array",
          "items": { "$ref": "#/$defs/voiceItem" }
        },
        "top_barriers": {
          "type": "array",
          "items": { "$ref": "#/$defs/voiceItem" }
        },
        "raw_quotes": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "quote": { "type": "string" },
              "source": { "type": "string" }
            }
          }
        }
      }
    },
    "marketing_patterns": {
      "type": "object",
      "properties": {
        "effective_headlines": {
          "type": "array",
          "items": { "type": "string" }
        },
        "effective_cta_contexts": {
          "type": "array",
          "items": { "type": "string" }
        },
        "content_calendar_hints": {
          "type": "array",
          "items": { "type": "string" }
        },
        "pricing_insights": {
          "type": "object",
          "properties": {
            "market_range": { "type": "string" },
            "sweet_spot": { "type": "string" },
            "premium_trigger": { "type": "string" }
          }
        }
      }
    },
    "trust_scores": {
      "type": "object",
      "properties": {
        "overall": { "type": "integer", "minimum": 0, "maximum": 100 },
        "by_layer": {
          "type": "object",
          "additionalProperties": { "type": "integer", "minimum": 0, "maximum": 100 }
        },
        "high_confidence_findings": {
          "type": "array",
          "items": { "type": "string" }
        },
        "low_confidence_findings": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    }
  },
  "$defs": {
    "personaDetail": {
      "type": "object",
      "properties": {
        "age_range": { "type": "string" },
        "gender": { "type": "string" },
        "concerns": { "type": "array", "items": { "type": "string" } },
        "motivations": { "type": "array", "items": { "type": "string" } },
        "barriers": { "type": "array", "items": { "type": "string" } },
        "information_sources": { "type": "array", "items": { "type": "string" } },
        "decision_factors": { "type": "array", "items": { "type": "string" } }
      }
    },
    "voiceItem": {
      "type": "object",
      "properties": {
        "concern": { "type": "string" },
        "motivation": { "type": "string" },
        "barrier": { "type": "string" },
        "frequency": { "type": "string", "enum": ["high", "medium", "low"] },
        "source": { "type": "string" }
      }
    }
  }
}
